    "/sii/f22/{year}": {
      "post": {
        "summary": "F22 Declaración de Renta",
        "description": "Consulta el estado de la Declaración de Renta (Formulario 22) de un contribuyente para el año tributario indicado. Inicia sesión en el SII, selecciona el período y extrae folio, estado, situación tributaria y observaciones.",
        "tags": ["SII - F22"],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "description": "Año tributario a consultar (ej: 2025)",
            "schema": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100,
              "example": 2025
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SIICredentials"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Estado de la Declaración de Renta para el año indicado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/F22Response"
                }
              }
            }
          },
          "400": {
            "description": "Error en los parámetros de entrada"
          },
          "401": {
            "description": "Token de autorización inválido"
          },
          "403": {
            "description": "Credenciales SII inválidas"
          },
          "429": {
            "description": "Límite de consultas excedido"
          }
        }
      }
    },
